# Application management
##########################################

function dev:install {
    cd "$(pwd)/src" || exit "$?"

    _install:lgr
    _install:brew

    _install:envset
    _install:changelog

    lgr ok "dependencies intalled..."
}

function dev:env:load {
    eval "$(envset development --isolated=true)"
}

function dev:test {
    go:test "$@"
}

function dev:test:verbose {
    go test ./... -v
}

function dev:race {
    go:race "$@"
}

function dev:cover {
    go:cover "$@"
}


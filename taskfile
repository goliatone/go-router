function go:mod:update {
    local modules
    local extra=()
    local mod
    local root
    local latest
    local root_latest
    local resolved
    local current_mod
    local go_bin

    if ! command -v rg >/dev/null 2>&1; then
        lgr ERR "rg is required to list goliatone modules"
        return 1
    fi

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1

    # Get current module name to exclude from updates (avoid self-update and submodules)
    current_mod=$("${go_bin}" list -m)

    modules=$(rg -o 'github.com/goliatone/[^[:space:]]+' go.mod | sort -u | grep -v "^${current_mod}")
    if [ -z "$modules" ]; then
        lgr ERR "no goliatone modules found in go.mod"
        return 1
    fi

    lgr I "updating goliatone modules to latest..."
    for mod in $modules; do
        latest=""
        resolved=0
        if latest=$("${go_bin}" list -m -u -f '{{if .Update}}{{.Update.Version}}{{else}}{{.Version}}{{end}}' "$mod" 2>/dev/null); then
            resolved=1
        fi

        if [ "$resolved" -eq 1 ] && [ -n "$latest" ]; then
            lgr I "go get ${mod}@${latest}"
            "${go_bin}" get "${mod}@${latest}" || return 1
            continue
        fi

        lgr WARN "failed to resolve latest for ${mod}, trying ${mod}@latest"
        if "${go_bin}" get -u "${mod}@latest"; then
            continue
        fi

        root=$(echo "$mod" | awk -F/ '{print $1"/"$2"/"$3}')
        if [ "$root" != "$mod" ]; then
            root_latest=""
            if root_latest=$("${go_bin}" list -m -u -f '{{if .Update}}{{.Update.Version}}{{else}}{{.Version}}{{end}}' "$root" 2>/dev/null); then
                lgr WARN "failed to update ${mod}, retrying ${root}@${root_latest}"
                "${go_bin}" get "${root}@${root_latest}" || return 1
            else
                lgr WARN "failed to resolve ${root}, retrying ${root}@latest"
                "${go_bin}" get -u "${root}@latest" || return 1
            fi
        else
            return 1
        fi
    done

    if [ "$#" -gt 0 ]; then
        for mod in "$@"; do
            extra+=("${mod}@latest")
        done
        lgr I "updating extra modules: ${extra[*]}"
        "${go_bin}" get -u "${extra[@]}" || return 1
    fi

    "${go_bin}" mod tidy
}

##
## ########################################
##           Version Management
## ########################################

##
## -----
##
## version:upsert
##
## Save version to meta file.
## First time will create file if not present
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:upsert {
    local tag=${1}

    if [ -z "$tag" ]; then
        version:get
    else
        version:set "$tag"
        version:get
    fi
}

##
## -----
##
## version:get
##
## Get version from meta file.
function version:get {

    test -f "${VERSION_FILE}" || touch "${VERSION_FILE}"

    local tag
    tag=$(cat "${VERSION_FILE}")

    if [ -z "$tag" ]; then
        tag="0.0.1"
        version:set "$tag"
    fi

    echo -n "$tag"
}

##
## -----
##
## version:set
##
## Set and save version to meta file.
## First time will create file if not present.
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:set {

    local tag
    tag=${1}
    if [ -z "$tag" ]; then
        exit 1
    fi

    version:check

    echo -e "$tag" > "${VERSION_FILE}"
}

##
## -----
##
## version:bump
## Bump sem ver by specifying a level.
## Valid levels are:
## - patch (default)
## - minor
## - major
##
## If you want to update the .version file
## pass the `--write` flag.
## @see https://github.com/fsaintjacques/semver-tool/blob/master/src/semver
##
## @arg 1 {string} [level=patch]
## Outputs:
##   Semver string "$major.$minor.$patch"
##
## @flag --write Will write to .version file
##
function version:bump {

    version:check

    # Default values
    level='patch'
    write_to_file=0

    # Parse options
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --write)
                write_to_file=1
                shift
            ;;
            patch|minor|major)
                level=$1
                shift
            ;;
            *)
                echo "Invalid option: $1"
                return 2
            ;;
        esac
    done

    # Read contents of version and store in
    IFS='.' read -ra identifiers < "$VERSION_FILE"

    [[ "${#identifiers[@]}" -ne 3 ]] && echo "Invalid semver string" && return 1

    patch=${identifiers[2]}
    minor=${identifiers[1]}
    major=${identifiers[0]}

    case $level in
        patch)
            patch=$((patch+1))
        ;;
        minor)
            minor=$((minor+1))
            patch=0
        ;;
        major)
            major=$((major+1))
            minor=0
            patch=0
        ;;
        *)
            echo "Invalid level passed"
            return 2
    esac

    new_version="$major.$minor.$patch"

    if [[ $write_to_file -eq 1 ]]; then
        echo "$new_version" > "${VERSION_FILE}"
    else
        echo "$new_version"
    fi
}

function version:check {
    if [ ! -f "$VERSION_FILE" ]; then
        echo "0.0.0" > "$VERSION_FILE"
    fi
}

function _version:package:get {
    local dir=$1

    (
        cd "$dir" || exit 1
        node -p "require('./package.json').version"
    )
}

function _version:package:set {
    local dir=$1
    local tag=$2

    (
        cd "$dir" || exit 1
        npm version "$tag" --no-git-tag-version --allow-same-version >/dev/null
    )
}

function _version:websocket_handler:get {
    sed -n 's/^[[:space:]]*WebSocketClientVersion = "\([^"]*\)".*/\1/p' websocket_client_handlers.go | head -n 1
}

function _version:websocket_handler:set {
    local tag=$1

    sed -i.bak "s/WebSocketClientVersion = \"[^\"]*\"/WebSocketClientVersion = \"$tag\"/" websocket_client_handlers.go
    rm -f websocket_client_handlers.go.bak
}

##
## -----
##
## version:sync
##
## Sync repo-managed version metadata to all published packages.
##
## Arguments:
## @arg 1 {string} [tag=$(version:get)]
function version:sync {
    local tag=${1:-$(version:get)}

    if [ -z "$tag" ]; then
        lgr E "version:sync requires a target version"
        return 1
    fi

    version:set "$tag"

    lgr I "Syncing package versions to ${tag}..."
    _version:package:set client "$tag" || return 1
    _version:package:set sseclient "$tag" || return 1
    _version:websocket_handler:set "$tag" || return 1

    version:verify-sync "$tag"
}

##
## -----
##
## version:verify-sync
##
## Verify that repo, client packages, and embedded Go metadata agree.
##
## Arguments:
## @arg 1 {string} [tag=$(version:get)]
function version:verify-sync {
    local expected=${1:-$(version:get)}
    local root_version
    local client_version
    local sseclient_version
    local websocket_handler_version

    root_version=$(version:get)
    client_version=$(_version:package:get client) || return 1
    sseclient_version=$(_version:package:get sseclient) || return 1
    websocket_handler_version=$(_version:websocket_handler:get)

    if [ "$root_version" != "$expected" ]; then
        lgr E "Root version mismatch: expected ${expected}, found ${root_version}"
        return 1
    fi

    if [ "$client_version" != "$expected" ]; then
        lgr E "WebSocket client version mismatch: expected ${expected}, found ${client_version}"
        return 1
    fi

    if [ "$sseclient_version" != "$expected" ]; then
        lgr E "SSE client version mismatch: expected ${expected}, found ${sseclient_version}"
        return 1
    fi

    if [ "$websocket_handler_version" != "$expected" ]; then
        lgr E "Embedded WebSocket client version mismatch: expected ${expected}, found ${websocket_handler_version}"
        return 1
    fi

    lgr OK "Versions are synchronized at ${expected}"
}


##
## -----
##
## release
##
## Bump our current version, create a git tag
## and push to trigger our release flow.
##
## Arguments:
## @arg 1 {string} [level=patch]
##        Accepted major, minor, patch
function release {
    local tag
    local level
    local message

    # Fetch all changes from origin
    git fetch --all
    # Make sure we have the latest version file
    git checkout origin/main -- ".version"

    # Pull tags to make sure we have
    git pull --tags -f

    level=${1:-"patch"}

    # Bump our version
    tag=$(version:bump "${level}")

    # Set message: default to New major|minor|patch release: vx.x.x
    message=${2:-"New ${level} release: v${tag}"}

    # Update version file
    version:set "${tag}"
    version:sync "${tag}" || return 1

    # Add updated version file to git
    git add "${VERSION_FILE}" \
        client/package.json client/package-lock.json \
        sseclient/package.json sseclient/package-lock.json \
        websocket_client_handlers.go
    git commit -m "Bump version: v${tag}"

    # Create a new tag
    git tag -a "v${tag}" -m "${message}"

    # Push tags and trigger release 🚀 🥳
    git push --tags
    git push

    # Generate changelog
    git cliff --output CHANGELOG.md
    git add CHANGELOG.md
    git commit -m "docs: update changelog for v${tag}"

    git push
}

##########################################
# Client Release Management
##########################################

##
## -----
##
## client:release
##
## Build and release the WebSocket client library.
## Updates package.json version, builds production files,
## and updates Go handler version constant.
##
## Arguments:
## @arg 1 {string} [level=patch] Version bump level (major, minor, patch)
##
function client:release {
    local tag

    if [[ "${1:-}" =~ ^(major|minor|patch)$ ]]; then
        lgr WARN "client:release uses the repo version. Run ./taskfile release ${1} first if you need to bump go-router."
    fi

    lgr I "Starting client release process..."
    tag=$(version:get)
    version:sync "$tag" || return 1

    # Navigate to client directory
    cd client || {
        lgr E "Client directory not found"
        return 1
    }

    lgr I "Cleaning previous builds..."
    npm run clean

    lgr I "Building production files..."
    npm run build
    npm run build:prod
    npm run build:types

    # Navigate back to root
    cd ..

    lgr I "Committing changes..."
    git add client/package.json client/package-lock.json client/client.js client/client.js.map client/client.min.js client/client.d.ts websocket_client_handlers.go
    if ! git diff --cached --quiet; then
        git commit -m "release: WebSocket client v${tag}"
    else
        lgr I "No WebSocket client release artifacts changed"
    fi

    lgr I "Creating release tag..."
    git tag -a "client-v${tag}" -m "WebSocket client release v${tag}"

    lgr OK "Client release completed successfully!"
    lgr I "Version synchronized to: $tag"
    lgr I "Tagged as: client-v${tag}"
}


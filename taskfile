##
## -----
##
## sseclient:release
##
## Build and prepare the SSE client library for tag-based npm publishing.
## The SSE client version is synchronized with the repo version in .version.
##
function sseclient:release {
    local tag

    if [[ "${1:-}" =~ ^(major|minor|patch)$ ]]; then
        lgr WARN "sseclient:release uses the repo version. Run ./taskfile release ${1} first if you need to bump go-router."
    fi

    tag=$(version:get)
    lgr I "Starting SSE client release process for v${tag}..."

    version:sync "$tag" || return 1

    cd sseclient || {
        lgr E "SSE client directory not found"
        return 1
    }

    lgr I "Installing dependencies..."
    npm ci || return 1

    lgr I "Running SSE client tests..."
    npm test || return 1

    lgr I "Building SSE client artifacts..."
    npm run build || return 1

    cd ..

    git add sseclient/package.json sseclient/package-lock.json sseclient/README.md sseclient/dist
    if ! git diff --cached --quiet; then
        git commit -m "release: SSE client v${tag}"
    else
        lgr I "No SSE client release artifacts changed"
    fi

    lgr I "Creating release tag..."
    git tag -a "sseclient-v${tag}" -m "SSE client release v${tag}"

    lgr OK "SSE client release completed successfully!"
    lgr I "Version synchronized to: ${tag}"
    lgr I "Tagged as: sseclient-v${tag}"
    lgr I "Push the commit and tag to trigger npm publication"
}


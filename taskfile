function go:tidy {
    local go_bin

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    "${go_bin}" mod tidy
}

function go:tools:golangci-lint {
    local version

    version="$(_go:golangci_lint_version)" || return 1
    _go:tool:install "golangci-lint" "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${version}"
}

function go:tools:govulncheck {
    _go:tool:install "govulncheck" "golang.org/x/vuln/cmd/govulncheck@${GO_GOVULNCHECK_VERSION}"
}


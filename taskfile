    go:tools:gosec || return 1
}

function go:fmt {
    local gofmt_bin
    local -a files=()

    gofmt_bin="$(dirname "$(_go:bin)")/gofmt"
    while IFS= read -r file; do
        if [ -n "${file}" ]; then
            files+=("${file}")
        fi
    done < <(_go:files)
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Go files found"
        return 0
    fi

    "${gofmt_bin}" -s -w "${files[@]}"
}

function go:fix {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
            patterns+=("${pattern}")
        fi
    done < <(_go:lint:patterns "$@")
    "${go_bin}" fix "${patterns[@]}"
}

function go:fmt:check {
    local gofmt_bin
    local -a files=()
    local unformatted

    gofmt_bin="$(dirname "$(_go:bin)")/gofmt"
    while IFS= read -r file; do
        if [ -n "${file}" ]; then
            files+=("${file}")
        fi
    done < <(_go:files)
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Go files found"
        return 0
    fi

    unformatted="$("${gofmt_bin}" -s -l "${files[@]}")"
    if [ -n "${unformatted}" ]; then
        echo "The following Go files need formatting:"
        echo "${unformatted}"
        return 1
    fi
}

